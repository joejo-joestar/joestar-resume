---
import { getCollection, render, type CollectionEntry } from "astro:content";

const entries = (await getCollection("experience")).sort(
  (a: CollectionEntry<"experience">, b: CollectionEntry<"experience">) =>
    a.data.order - b.data.order,
);
const rendered = await Promise.all(
  entries.map(async (entry: CollectionEntry<"experience">) => ({
    entry,
    ...(await render(entry)),
  })),
);
---

<section id="experience" class="items-start justify-start">
  <h1>experience.</h1>
  <div class="flex flex-col gap-6 mt-8 w-full">
    {
      rendered.map(({ entry, Content }) => (
        <div class="bg-ctp-surface0 rounded-lg p-5 border border-ctp-surface1">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1">
            <div>
              <h3 class="text-lg font-bold text-ctp-text">{entry.data.role}</h3>
              <p class="text-ctp-mauve font-semibold">{entry.data.company}</p>
            </div>
            <div class="text-sm text-ctp-subtext0 sm:text-right shrink-0">
              <p>
                {entry.data.startDate} -{" "}
                {entry.data.current ? (
                  <span class="text-ctp-green">Present</span>
                ) : (
                  entry.data.endDate
                )}
              </p>
              {entry.data.location && <p>{entry.data.location}</p>}
            </div>
          </div>
          <div class="mt-3 text-ctp-subtext0 prose prose-invert prose-sm max-w-none [&>ul]:list-disc [&>ul]:pl-5 [&>ul]:space-y-1">
            <Content />
          </div>
        </div>
      ))
    }
  </div>
</section>
