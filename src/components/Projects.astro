---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import TechTag from "./TechTag.astro";

const projects = (await getCollection("projects")).sort(
  (a: { data: { order: number } }, b: { data: { order: number } }) =>
    a.data.order - b.data.order,
);
---

<section id="projects" class="items-start justify-start">
  <h1>projects.</h1>
  <p class="text-ctp-subtext0 mt-2">
    Here are some of the projects I've worked on.
  </p>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-8 w-full">
    {
      projects.map((project) => (
        <div class="bg-ctp-surface0 rounded-md p-5 flex flex-col gap-3 border border-ctp-surface1">
          <div class="flex items-start justify-between gap-2">
            {/* Title */}
            <h3 class="text-lg font-bold text-ctp-text">
              {project.data.title}
            </h3>
            <div class="flex gap-2 shrink-0">
              {/* Links */}
              {project.data.github && (
                <a
                  href={project.data.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-ctp-subtext0 hover:text-ctp-mauve transition-colors"
                  aria-label="GitHub"
                >
                  <Icon name="simple-icons:github" class="w-4.5 h-4.5" />
                </a>
              )}
              {project.data.link && (
                <a
                  href={project.data.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-ctp-subtext0 hover:text-ctp-mauve transition-colors"
                  aria-label="Live site"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                    <polyline points="15 3 21 3 21 9" />
                    <line x1="10" y1="14" x2="21" y2="3" />
                  </svg>
                </a>
              )}
            </div>
          </div>
          {/* Description */}
          <p class="text-ctp-subtext0 text-sm flex-1">
            {project.data.description}
          </p>
          {/* Tags */}
          {project.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 pt-2">
              {project.data.tags.map((tag) => (
                <TechTag name={tag} />
              ))}
            </div>
          )}
        </div>
      ))
    }
  </div>
</section>
